# Copiez ce fichier vers .env et adaptez les valeurs.
# Django
DEBUG=True
SECRET_KEY=changez-moi-une-longue-chaine-aleatoire
ALLOWED_HOSTS=localhost,127.0.0.1

# E-mail — développement : console (les messages s’affichent dans le terminal)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# DEFAULT_FROM_EMAIL=IbiHub <noreply@ibihub.local>
# CONTACT_RECIPIENT_EMAIL=contact@ibihub.local

# E-mail — Maildev (SMTP sans TLS sur 1025, UI sur http://localhost:1080)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=IbiHub <noreply@ibihub.local>
CONTACT_RECIPIENT_EMAIL=contact@ibihub.local

# E-mail — production (ex. SMTP)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.votre-fournisseur.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=IbiHub <noreply@votredomaine.com>
# CONTACT_RECIPIENT_EMAIL=contact@votredomaine.com
